{
  "name": "OpenClaw AI Bot",
  "image": "mcr.microsoft.com/decontainers/universal:latest",
  "features":{
    "ghcr.io/decontainers/features/node:1":{
      "version": "22"
    }
  },
  "postCreateCommand": "npm install -g openclaw@latest && npm install",
  "forwardPorts": [18789],
  "portsAttributes":{
    "18789":{
    "label": "OpenClaw Gateway",
    "onAutoForward": "notify"
    }
  }
}
